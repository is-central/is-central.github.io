---
const { phases } = Astro.props;

function getStatus(startStr, endStr) {
  const now = new Date();
  const start = new Date(startStr);
  if (now < start) return "upcoming";
  if (!endStr) return "live";
  const end = new Date(endStr);
  return now <= end ? "live" : "done";
}

function formatRange(startStr, endStr) {
  const fmt = (d) =>
    `${d.getDate()} ${d.toLocaleString("en", { month: "short" })} ${d.getFullYear()}`;
  if (!endStr) return fmt(new Date(startStr));
  return `${fmt(new Date(startStr))} – ${fmt(new Date(endStr))}`;
}

const STATUS_LABEL = { done: "Concluded", live: "Live", upcoming: "Upcoming" };
---

<div class="phase-timeline">
  {phases.map((phase, i) => {
    const status = getStatus(phase.startDate, phase.endDate);
    const dateLabel = formatRange(phase.startDate, phase.endDate);
    const isLast = i === phases.length - 1;
    return (
      <div class="phase-step">
        <div class="step-rail">
          <div class:list={["step-dot", `dot-${status}`]} />
          {!isLast && <div class="step-line" />}
        </div>
        <div class:list={["step-body", { "step-upcoming": status === "upcoming" }]}>
          <div class="step-header">
            <span class="step-name">{phase.name}</span>
            <span class:list={["step-badge", `badge-${status}`]}>{STATUS_LABEL[status]}</span>
          </div>
          <span class="step-date">{dateLabel}</span>
          {phase.links?.length > 0 && (
            <div class="step-links">
              {phase.links.map((link) => (
                <a href={link.href} class="step-link">{link.label}</a>
              ))}
            </div>
          )}
        </div>
      </div>
    );
  })}
</div>

<style>
  .phase-timeline {
    display: flex;
    flex-direction: column;
    margin: 1rem 0;
  }

  .phase-step {
    display: flex;
    gap: 0.9rem;
    align-items: stretch;
  }

  /* ── Rail ── */
  .step-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
    padding-top: 3px;
  }

  .step-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 2px solid color-mix(in srgb, var(--sl-color-gray-5) 80%, transparent);
    background: var(--sl-color-bg);
    position: relative;
    z-index: 1;
  }

  .dot-done {
    background: var(--sl-color-gray-4);
    border-color: var(--sl-color-gray-4);
  }

  .dot-live {
    background: #4ade80;
    border-color: #4ade80;
    box-shadow: 0 0 0 3px color-mix(in srgb, #4ade80 20%, transparent);
  }

  .dot-upcoming {
    background: var(--sl-color-bg);
    border-color: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
  }

  .step-line {
    flex: 1;
    width: 1px;
    background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    margin: 4px 0;
    min-height: 12px;
  }

  /* ── Body ── */
  .step-body {
    flex: 1;
    padding: 0 0 1.2rem;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .step-upcoming {
    opacity: 0.6;
  }

  .step-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .step-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .step-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .badge-done {
    background: color-mix(in srgb, var(--sl-color-gray-5) 40%, transparent);
    color: var(--sl-color-gray-3);
  }

  .badge-live {
    background: color-mix(in srgb, #4ade80 15%, transparent);
    color: #16a34a;
  }

  .badge-upcoming {
    background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent);
    color: var(--sl-color-gray-3);
  }

  .step-date {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
    font-variant-numeric: tabular-nums;
  }

  .step-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.15rem;
  }

  .step-link {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    border-radius: 5px;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .step-link:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
    color: var(--sl-color-accent);
  }
</style>