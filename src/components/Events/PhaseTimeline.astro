---
const { phases, themes } = Astro.props;

const IS_COLORS = {
  IS2: "#FBC02D",
  IS3: "#3949AB",
  IS4: "#64B5F6",
  IS5: "#B71C1C",
  IS6: "#EC407A",
};

// Normalise themes to an array of hex colors
const themeList = (() => {
  if (!themes) return [];
  const arr = Array.isArray(themes) ? themes : [themes];
  return arr.map(t => IS_COLORS[t.trim()] ?? null).filter(Boolean);
})();

// Assign a color to each phase — cycles if fewer themes than phases
function phaseColor(index) {
  if (themeList.length === 0) return null;
  return themeList[index % themeList.length];
}

function hasTime(dateStr) {
  return dateStr && dateStr.includes("T");
}

function getStatus(startStr, endStr) {
  const now = new Date();
  const start = new Date(startStr);
  if (now < start) return "upcoming";
  if (!endStr) return "live";
  const end = new Date(endStr);
  return now <= end ? "live" : "done";
}

function formatUTC(dateStr, includeTime) {
  const d = new Date(dateStr);
  const day   = d.getUTCDate();
  const month = d.toLocaleString("en", { month: "short", timeZone: "UTC" });
  const year  = d.getUTCFullYear();
  if (!includeTime) return `${day} ${month} ${year}`;
  const hh = String(d.getUTCHours()).padStart(2, "0");
  const mm = String(d.getUTCMinutes()).padStart(2, "0");
  return `${day} ${month} ${year}, ${hh}:${mm}`;
}

function formatRange(startStr, endStr, includeTime) {
  const s = formatUTC(startStr, includeTime);
  if (!endStr) return s;
  const e = formatUTC(endStr, includeTime);
  return `${s} – ${e}`;
}

const anyHasTime = phases.some((p) => hasTime(p.startDate) || hasTime(p.endDate));

const STATUS_LABEL = { done: "Concluded", live: "Live", upcoming: "Upcoming" };

const UTC_OFFSETS = [
  { label: "UTC−12", value: -720 }, { label: "UTC−11", value: -660 },
  { label: "UTC−10", value: -600 }, { label: "UTC−9",  value: -540 },
  { label: "UTC−8",  value: -480 }, { label: "UTC−7",  value: -420 },
  { label: "UTC−6",  value: -360 }, { label: "UTC−5",  value: -300 },
  { label: "UTC−4",  value: -240 }, { label: "UTC−3",  value: -180 },
  { label: "UTC−2",  value: -120 }, { label: "UTC−1",  value: -60  },
  { label: "UTC+0",  value: 0    },
  { label: "UTC+1",  value: 60   }, { label: "UTC+2",  value: 120  },
  { label: "UTC+3",  value: 180  }, { label: "UTC+4",  value: 240  },
  { label: "UTC+5",  value: 300  }, { label: "UTC+5:30", value: 330 },
  { label: "UTC+6",  value: 360  }, { label: "UTC+7",  value: 420  },
  { label: "UTC+8",  value: 480  }, { label: "UTC+9",  value: 540  },
  { label: "UTC+10", value: 600  }, { label: "UTC+11", value: 660  },
  { label: "UTC+12", value: 720  },
];
---

<div class="phase-wrap">
  {anyHasTime && (
    <div class="tz-controls">
      <span class="tz-label">Time zone</span>
      <div class="tz-options">
        <button class="tz-btn active" data-tz="local">Local</button>
        <button class="tz-btn" data-tz="utc">UTC</button>
        <button class="tz-btn" data-tz="custom">Custom</button>
      </div>
      <select class="tz-select" style="display:none">
        {UTC_OFFSETS.map((o) => (
          <option value={o.value}>{o.label}</option>
        ))}
      </select>
    </div>
  )}

  <div class="phase-timeline">
    {phases.map((phase, i) => {
      const status = getStatus(phase.startDate, phase.endDate);
      const phaseHasTime = hasTime(phase.startDate) || hasTime(phase.endDate);
      const dateLabel = formatRange(phase.startDate, phase.endDate, phaseHasTime);
      const isLast = i === phases.length - 1;
      const color = phaseColor(i);
      return (
        <div class="phase-step" style={color ? `--phase-color: ${color}` : ""}>
          <div class="step-rail">
            <div class:list={["step-dot", `dot-${status}`, { "dot-themed": !!color }]} />
            {!isLast && <div class:list={["step-line", { "line-themed": !!color }]} />}
          </div>
          <div class:list={["step-body", { "step-upcoming": status === "upcoming" }]}>
            <div class="step-header">
              <span class="step-name">{phase.name}</span>
              <span class:list={["step-badge", `badge-${status}`, { "badge-themed": !!color }]}>{STATUS_LABEL[status]}</span>
            </div>
            <span
              class="step-date"
              data-start={phase.startDate}
              data-end={phase.endDate ?? ""}
              data-has-time={phaseHasTime ? "1" : "0"}
            >
              {dateLabel}
            </span>
            {phase.links?.length > 0 && (
              <div class="step-links">
                {phase.links.map((link) => (
                  <a href={link.href} class:list={["step-link", { "link-themed": !!color }]}>{link.label}</a>
                ))}
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>
</div>

<script>
  function fmtDate(d, includeTime) {
    const day   = d.getDate();
    const month = d.toLocaleString("en", { month: "short" });
    const year  = d.getFullYear();
    if (!includeTime) return `${day} ${month} ${year}`;
    const hh = String(d.getHours()).padStart(2, "0");
    const mm = String(d.getMinutes()).padStart(2, "0");
    return `${day} ${month} ${year}, ${hh}:${mm}`;
  }

  function fmtOffset(isoStr, offsetMins, includeTime) {
    const d = new Date(new Date(isoStr).getTime() + offsetMins * 60000);
    const shifted = new Date(d.toISOString().slice(0, -1));
    return fmtDate(shifted, includeTime);
  }

  function updateDates(mode, customOffset) {
    document.querySelectorAll(".step-date[data-start]").forEach((el) => {
      const start   = el.getAttribute("data-start");
      const end     = el.getAttribute("data-end");
      const hasTime = el.getAttribute("data-has-time") === "1";
      if (!hasTime) return;

      let fmtStart, fmtEnd;

      if (mode === "utc") {
        fmtStart = fmtOffset(start, 0, true);
        fmtEnd   = end ? fmtOffset(end, 0, true) : null;
      } else if (mode === "local") {
        fmtStart = fmtDate(new Date(start), true);
        fmtEnd   = end ? fmtDate(new Date(end), true) : null;
      } else {
        fmtStart = fmtOffset(start, customOffset, true);
        fmtEnd   = end ? fmtOffset(end, customOffset, true) : null;
      }

      el.textContent = fmtEnd ? `${fmtStart} – ${fmtEnd}` : fmtStart;
    });
  }

  const btns   = document.querySelectorAll(".phase-wrap .tz-btn");
  const select = document.querySelector(".phase-wrap .tz-select");
  let mode = "local";
  let customOffset = 0;

  if (select) {
    const local = -new Date().getTimezoneOffset();
    let best = 0, bestDiff = Infinity;
    select.querySelectorAll("option").forEach((opt, i) => {
      const diff = Math.abs(Number(opt.value) - local);
      if (diff < bestDiff) { bestDiff = diff; best = i; }
    });
    select.selectedIndex = best;
    customOffset = Number(select.value);
  }

  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      btns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      mode = btn.dataset.tz;
      if (select) select.style.display = mode === "custom" ? "inline-block" : "none";
      if (mode === "custom") customOffset = Number(select.value);
      updateDates(mode, customOffset);
    });
  });

  if (select) {
    select.addEventListener("change", () => {
      customOffset = Number(select.value);
      updateDates("custom", customOffset);
    });
  }

  // Initial render — local by default
  updateDates("local", 0);
</script>

<style>
  .phase-wrap * {
    margin-top: 0;
    margin-bottom: 0;
  }

  .tz-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .tz-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .tz-options {
    display: flex;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 40%, transparent);
    border-radius: 6px;
    overflow: hidden;
  }

  .tz-btn {
    background: none;
    border: none;
    border-right: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 40%, transparent);
    padding: 0.25rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }

  .tz-btn:last-child { border-right: none; }
  .tz-btn:hover { background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent); color: var(--sl-color-gray-2); }
  .tz-btn.active { background: var(--sl-color-gray-6); color: var(--sl-color-white); }

  .tz-select {
    font-size: 0.72rem;
    padding: 0.2rem 0.4rem;
    border-radius: 5px;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 40%, transparent);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    cursor: pointer;
  }

  .phase-timeline {
    display: flex;
    flex-direction: column;
  }

  .phase-step {
    display: flex;
    gap: 0.9rem;
    align-items: stretch;
  }

  .step-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
    padding-top: 3px;
  }

  .step-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 2px solid color-mix(in srgb, var(--sl-color-gray-5) 80%, transparent);
    background: var(--sl-color-bg);
    position: relative;
    z-index: 1;
  }

  .dot-done     { background: var(--sl-color-gray-4); border-color: var(--sl-color-gray-4); }
  .dot-live     { background: #4ade80; border-color: #4ade80; box-shadow: 0 0 0 3px color-mix(in srgb, #4ade80 20%, transparent); }
  .dot-upcoming { background: var(--sl-color-bg); border-color: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent); }

  /* Themed dot overrides */
  .dot-themed.dot-done     { background: color-mix(in srgb, var(--phase-color) 60%, var(--sl-color-gray-4)); border-color: color-mix(in srgb, var(--phase-color) 60%, var(--sl-color-gray-4)); }
  .dot-themed.dot-live     { background: var(--phase-color); border-color: var(--phase-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--phase-color) 20%, transparent); }
  .dot-themed.dot-upcoming { border-color: color-mix(in srgb, var(--phase-color) 40%, transparent); }

  .step-line {
    flex: 1;
    width: 1px;
    background: color-mix(in srgb, var(--sl-color-gray-5) 60%, transparent);
    margin: 4px 0;
    min-height: 12px;
  }

  .line-themed { background: color-mix(in srgb, var(--phase-color) 30%, transparent); }

  .step-body {
    flex: 1;
    padding: 0 0 1.2rem;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .step-upcoming { opacity: 0.6; }

  .step-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .step-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .step-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .badge-done     { background: color-mix(in srgb, var(--sl-color-gray-5) 40%, transparent); color: var(--sl-color-gray-3); }
  .badge-live     { background: color-mix(in srgb, #4ade80 15%, transparent); color: #16a34a; }
  .badge-upcoming { background: color-mix(in srgb, var(--sl-color-gray-5) 30%, transparent); color: var(--sl-color-gray-3); }

  /* Themed badge overrides */
  .badge-themed.badge-done     { background: color-mix(in srgb, var(--phase-color) 12%, transparent); color: color-mix(in srgb, var(--phase-color) 80%, var(--sl-color-gray-3)); border: 1px solid color-mix(in srgb, var(--phase-color) 25%, transparent); }
  .badge-themed.badge-live     { background: color-mix(in srgb, var(--phase-color) 15%, transparent); color: var(--phase-color); border: 1px solid color-mix(in srgb, var(--phase-color) 40%, transparent); }
  .badge-themed.badge-upcoming { background: color-mix(in srgb, var(--phase-color) 8%, transparent); color: color-mix(in srgb, var(--phase-color) 60%, var(--sl-color-gray-3)); border: 1px solid color-mix(in srgb, var(--phase-color) 20%, transparent); }

  .step-date {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
    font-variant-numeric: tabular-nums;
  }

  .step-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .step-link {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 50%, transparent);
    border-radius: 6px;
    color: var(--sl-color-gray-2);
    background: color-mix(in srgb, var(--sl-color-gray-6) 60%, transparent);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .step-link:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 45%, transparent);
    color: var(--sl-color-accent);
  }

  /* Themed link buttons */
  .link-themed {
    border-color: color-mix(in srgb, var(--phase-color) 40%, transparent);
    color: color-mix(in srgb, var(--phase-color) 90%, var(--sl-color-gray-2));
    background: color-mix(in srgb, var(--phase-color) 8%, transparent);
  }

  .link-themed:hover {
    background: color-mix(in srgb, var(--phase-color) 18%, transparent);
    border-color: color-mix(in srgb, var(--phase-color) 65%, transparent);
    color: var(--phase-color);
  }
</style>